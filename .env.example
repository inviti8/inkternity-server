# Inkternity Server Configuration
# Copy this file to .env and fill in your values.

# ============================================================
# Domains
# ============================================================
# WebSocket signaling endpoint (clients connect to wss://${DOMAIN_SIGNAL}/<globalID>)
DOMAIN_SIGNAL=signal.heavymeta.art

# TURN/STUN endpoint (used by clients as a relay when direct P2P fails)
DOMAIN_TURN=turn.heavymeta.art

# ============================================================
# TURN credentials
# ============================================================
# These get baked into the Inkternity client's default_p2p.json. Keep them
# stable across deployments unless rotating; clients won't auto-discover changes.
# Generate the secret with: openssl rand -hex 32
TURN_USERNAME=inkternity
TURN_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32

# Realm coturn advertises (cosmetic / authentication scope)
TURN_REALM=heavymeta.art

# UDP port range coturn allocates for relayed media. The defaults are wide
# enough for hundreds of concurrent sessions; narrow if your provider charges
# per-port. Whatever range is set here MUST be opened in the host firewall.
TURN_MIN_PORT=49152
TURN_MAX_PORT=65535

# ============================================================
# Operations
# ============================================================
# Email used by certbot for Let's Encrypt registration / expiry warnings.
LETSENCRYPT_EMAIL=ops@heavymeta.art

# Set to true once you have valid Let's Encrypt certs in /etc/letsencrypt;
# nginx will then bind on :443 with TLS. Set to false on first boot to let
# the bootstrap script run certbot in HTTP-01 mode against :80.
TLS_ENABLED=false

# Logging
LOG_LEVEL=INFO
